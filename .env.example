# Copy to ~/.config/ingar/ingar.env on the Pi and fill in.

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME

# Set to 1 while breadboarding / before talking to the real freezer.
# All Slack messages get a "[TESTING] " prefix.
INGAR_TESTING=1

# BCM pin number wired to the NC terminal.
INGAR_ALARM_PIN=17

# Tuning (defaults shown).
INGAR_POLL_INTERVAL_S=1.0
INGAR_DEBOUNCE_S=2.0
# Heartbeat to Slack so lab members can eyeball that monitor is alive.
# 300s (5 min) for breadboard verification; raise to 21600 (6h) before going
# live or you'll carpet-bomb the channel.
INGAR_HEARTBEAT_INTERVAL_S=300

# Hardware-free testing: read state from a file instead of GPIO.
# echo 1 > /tmp/ingar_stub_state  # simulate alarm
# echo 0 > /tmp/ingar_stub_state  # simulate normal
STUB_GPIO=0
STUB_STATE_FILE=/tmp/ingar_stub_state
